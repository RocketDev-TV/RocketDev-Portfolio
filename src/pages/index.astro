---

<Layout title="Ignacio Herrera | Backend & Cloud Engineer">
  <main class="max-w-5xl mx-auto px-4 md:px-6 py-20 flex flex-col gap-24 md:gap-32 w-full overflow-x-hidden">

    <section class="flex flex-col md:flex-row items-center gap-12 pt-10">
      <div class="flex-1 order-2 md:order-1 text-center md:text-left">
        <div class="flex flex-col gap-4 items-center md:items-start">
          <ServerStatus />
          <div class="text-zinc-500 font-mono text-[10px] uppercase tracking-[0.2em] flex flex-wrap justify-center md:justify-start gap-x-6 gap-y-2">
            <span>📍 CDMX, México</span>
            <span>⏰ UTC-06 (CST)</span>
            <span class="text-violet-400/80 font-bold">📞 +52 55 4014 0384</span>
          </div>
        </div>

        <h1 class="text-6xl md:text-8xl font-black text-white mt-8 mb-6 tracking-tighter leading-[0.9] cyber-glow">
          IGNACIO <span class="text-violet-400">HERRERA</span>
        </h1>

        <p class="text-lg text-zinc-400 max-w-xl leading-relaxed font-medium mx-auto md:mx-0">
          Ingeniero en la <span class="text-zinc-200">UPIICSA - IPN</span>. Especialista en Backend, Cloud y Ciencia de Datos. Arquitecto de sistemas escalables y entornos Self-hosting.
        </p>

        <div class="flex flex-wrap justify-center md:justify-start gap-4 mt-10">
          <a
            href="/others/CV-Ignacio.pdf"
            download
            class="group bg-white text-black px-8 py-4 rounded-2xl font-bold hover:bg-violet-500 hover:text-white transition-all active:scale-95 flex items-center gap-2 shadow-lg shadow-white/5"
          >
            Descargar CV
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" x2="12" y1="15" y2="3"></line>
            </svg>
          </a>
          <div class="flex gap-3">
            <a
              href="https://github.com/RocketDev-TV/RocketDev-Portfolio"
              target="_blank"
              class="flex items-center gap-2 px-5 py-4 bg-violet-500/10 border border-violet-500/20 rounded-2xl hover:bg-violet-500/20 hover:border-violet-500/40 transition-all text-violet-400 group/repo"
              title="Ver código de este sitio"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                <path d="M9 18c-4.51 2-5-2-7-2"></path>
              </svg>
              <span class="text-xs font-bold uppercase tracking-widest hidden sm:inline">Source Code</span>
            </a>
            <a href="https://github.com/RocketDev-TV" target="_blank" class="p-4 bg-zinc-900 border border-zinc-800 rounded-2xl hover:border-violet-500/50 hover:bg-zinc-800 transition-all text-zinc-400 hover:text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
            </a>
            <a href="https://www.linkedin.com/in/ivanhg-dev/" target="_blank" class="p-4 bg-zinc-900 border border-zinc-800 rounded-2xl hover:border-violet-500/50 hover:bg-zinc-800 transition-all text-zinc-400 hover:text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            </a>
            <a href="https://www.instagram.com/rocketdev.tv/" target="_blank" class="p-4 bg-zinc-900 border border-zinc-800 rounded-2xl hover:border-violet-500/50 hover:bg-zinc-800 transition-all text-zinc-400 hover:text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="w-64 h-64 md:w-80 md:h-80 shrink-0 order-1 md:order-2 group mx-auto md:mx-0">
        <div class="w-full h-full rounded-[40px] border-4 border-zinc-900 overflow-hidden shadow-2xl rotate-3 group-hover:rotate-0 transition-all duration-700 relative">
          <img src="/img/FotoPerfil.jpeg" alt="Ignacio Herrera" class="w-full h-full object-cover" />
        </div>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-10 flex items-center gap-4 text-white">
        <span class="w-12 h-[2px] bg-violet-500 shadow-[0_0_8px_rgba(139,92,246,0.8)]"></span> Tecnologías & Aptitudes
      </h2>
      <div class="flex flex-col gap-8 w-full">
        {techCategories.map((cat) => (
          <div class="space-y-3">
            <h3 class="font-bold uppercase tracking-widest text-xs text-violet-400">{cat.name}</h3>
            <div class="flex flex-wrap gap-2">
              {cat.badges.map((badge) => (
                <img src={badge.url} alt={badge.label} class="h-7" loading="lazy" />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-10 text-white flex items-center gap-4">
        <span class="w-12 h-[2px] bg-violet-500 shadow-[0_0_8px_rgba(139,92,246,0.8)]"></span> Proyectos Destacados
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full">
        {projects.map((project) => (
            <div class="group bg-zinc-900/50 border border-zinc-800 rounded-[32px] p-6 md:p-8 hover:border-violet-500/30 transition-all flex flex-col justify-between h-full overflow-hidden">
              <div>
                <div class="text-violet-400 mb-6 group-hover:scale-110 transition-transform w-fit">
                  {project.icon === "music" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 18V5l12-2v13" /><circle cx="6" cy="18" r="3" /><circle cx="18" cy="16" r="3" />
                    </svg>
                  )}
                  {project.icon === "scissors" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="6" cy="6" r="3" /><circle cx="6" cy="18" r="3" /><line x1="20" y1="4" x2="8.12" y2="15.88" /><line x1="14.47" y1="14.48" x2="20" y2="20" /><line x1="8.12" y1="8.12" x2="12" y2="12" />
                    </svg>
                  )}
                  {project.icon === "code" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="16 18 22 12 16 6" /><polyline points="8 6 2 12 8 18" />
                    </svg>
                  )}
                  {project.icon === "gamepad" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="6" y1="12" x2="10" y2="12"></line>
                      <line x1="8" y1="10" x2="8" y2="14"></line>
                      <line x1="15" y1="13" x2="15.01" y2="13"></line>
                      <line x1="18" y1="11" x2="18.01" y2="11"></line>
                      <rect width="20" height="12" x="2" y="6" rx="2"></rect>
                    </svg>
                  )}
                  {project.icon === "terminal" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line>
                    </svg>
                  )}
                  {project.icon === "layers" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline>
                    </svg>
                  )}
                  {project.icon === "shield" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    </svg>
                  )}
                  {project.icon === "contacts" && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M15 13a3 3 0 1 0-6 0"></path>
                      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                      <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"></path>
                      <circle cx="12" cy="8" r="2"></circle>
                    </svg>
                  )}
                </div>
                <h3 class="text-2xl font-black text-white mb-3 tracking-tight">{project.title}</h3>
                <p class="text-zinc-400 text-sm leading-relaxed mb-8">{project.description}</p>
              </div>
              <button
                onclick={`document.getElementById('modal-${project.id}').showModal()`}
                class="text-xs font-bold uppercase tracking-widest text-violet-400 hover:text-violet-300 transition-colors flex items-center gap-2 w-fit"
              >
                Saber más <span>→</span>
              </button>
            </div>
          ))
        }
      </div>
    </section>

    <section>
