                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
            </button>

            <div class="overflow-y-auto p-6 sm:p-10 flex-1 hide-scrollbar">
              <div class="flex items-center gap-4 mb-6 pr-10">
                <div class="p-3 bg-violet-500/10 border border-violet-500/20 text-violet-400 rounded-2xl shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3" /></svg>
                </div>
                <h3 class="text-xl sm:text-3xl font-black text-white tracking-tight break-words">{project.title}</h3>
              </div>

              {project.images && project.images.length > 0 && (
                <div class="relative rounded-2xl overflow-hidden border border-zinc-800 bg-zinc-950 mb-6 aspect-video flex items-center justify-center shrink-0">
