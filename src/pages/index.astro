              </div>
            </div>

            <div class="p-4 sm:p-6 bg-zinc-950/90 border-t border-zinc-800/80 flex flex-col sm:flex-row gap-3 shrink-0">
              <a href={project.repo} target="_blank" class="flex-1 bg-zinc-800 hover:bg-zinc-700 py-3.5 rounded-xl font-bold flex justify-center items-center gap-2 transition-colors active:scale-95 text-sm text-white border border-zinc-700">
                Ver Código
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.28 1.15-.28 2.35 0 3.5-.73 1.02-1.08 2.25-1 3.5 0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                  <path d="M9 18c-4.51 2-5-2-7-2" />
                </svg>
              </a>

              {project.deploy && (
                <a href={project.deploy} target="_blank" class="flex-1 bg-violet-600 hover:bg-violet-500 py-3.5 rounded-xl font-bold flex justify-center items-center gap-2 transition-all active:scale-95 text-sm text-white shadow-lg shadow-violet-900/20">
                  Probar App
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <polyline points="15 3 21 3 21 9" />
                    <line x1="10" x2="21" y1="14" y2="3" />
                  </svg>
                </a>
              )}
            </div>

          </div>
        </dialog>
      ))
