---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import ServerStatus from "../components/ServerStatus.astro";

const projects = [
  {
    id: "spotify",
    title: "Streaming App",
    icon: "music",
    description:
      "Plataforma de streaming personal con arquitectura de microservicios autogestionada.",
    longDesc:
      "Desarrollé una API REST robusta con Flask y Supabase para el almacenamiento de metadatos. El sistema está optimizado para streaming de audio de alta fidelidad desde mi propio servidor doméstico.",
    tags: ["Python", "Flask", "Supabase", "Linux"],
    repo: "https://github.com/RocketDev-TV/NuevoSpotify",
    images: ["/img/NS/Streaming.png"],
  },
  {
    id: "barber",
    title: "Barbería API",
    icon: "scissors",
    description:
      "Sistema empresarial de gestión de citas y administración de sucursales con arquitectura escalable.",
    longDesc:
      "Implementado con Spring Boot y Azure, este sistema permite el control total de agendas, ingresos estimados y perfiles de barberos en tiempo real.",
    tags: ["Java", "Spring Boot", "Azure", "SQL"],
    repo: "https://github.com/RocketDev-TV/sistema-citas-web",
    images: ["/img/SBarberia/SistemaBarberia.png"],
  },
  {
    id: "instruccional",
    title: "Diseño Instruccional",
    icon: "code",
    description:
      "Core Backend desarrollado con NestJS y GraphQL para la gestión de contenidos educativos.",
    longDesc:
      "Arquitectura empresarial pensada para la administración modular de cursos, lecciones y evaluaciones interactivas, asegurando alta disponibilidad y consultas eficientes.",
    tags: ["TypeScript", "NestJS", "GraphQL", "Prisma"],
    repo: "https://github.com/RocketDev-TV/DI-respaldoFrontYBack",
    deploy: "https://anton-server.tailb29b29.ts.net/",
    images: ["/img/DI/DI.jpeg"],
  },
  {
    id: "moon",
    title: "Proyecto Moon",
    icon: "gamepad",
    description:
      "Videojuego desarrollado desde cero en el navegador con mecánicas originales y despliegue en la nube.",
    longDesc:
      "Proyecto Moon es un videojuego web construido con JavaScript puro. Diseñé cada mecánica, nivel y asset desde cero, explorando el desarrollo de videojuegos en canvas para el navegador. Desplegado en Vercel para disponibilidad inmediata.",
    tags: ["JavaScript", "Game Dev", "Canvas", "Vercel"],
    repo: "https://github.com/RocketDev-TV/Proyecto-Moon",
    deploy: "https://proyecto-moon.vercel.app/",
    images: ["/img/Moon/moonGame.jpeg"],
  },
  {
    id: "regresion",
    title: "Linear Regression Visualizer",
    icon: "terminal",
    description:
      "Aplicación interactiva para el cálculo paso a paso de Regresión Lineal Simple por Mínimos Cuadrados.",
    longDesc:
      "Desarrollada como una herramienta didáctica para ingeniería. No solo calcula el resultado óptimo, sino que desglosa detalladamente el procedimiento matemático, generando las tablas de cálculos intermedios y las fórmulas aplicadas paso a paso.\n\n💡 Nota: Desplegado en Render (servidor gratuito), puede tardar cerca de un minuto en cargar la primera vez mientras despierta el contenedor.",
    tags: ["Data Science", "JavaScript", "Matemáticas", "Web"],
    repo: "https://github.com/RocketDev-TV/regresion-lineal",
    deploy: "https://regresion-lineal-25br.onrender.com",
    images: ["/img/Regresion/RegresionL.jpeg"],
  },
  {
    id: "frecuencias",
    title: "Tablas de Frecuencia",
    icon: "layers",
    description:
      "Procesador estadístico para el cálculo y graficación de datos no agrupados.",
    longDesc:
      "Herramienta ágil diseñada para automatizar la estructuración de datos estadísticos. Genera de forma automática la tabla de frecuencias completas, el histograma y el polígono de frecuencias correspondiente.\n\n💡 Nota: Desplegado en Render (servidor gratuito), puede tardar cerca de un minuto en cargar la primera vez mientras despierta el contenedor.",
    tags: ["Estadística", "Data Science", "Charts", "Frontend"],
    repo: "https://github.com/RocketDev-TV/Tablas-Frecuencia-D.NoAgrupados",
    deploy: "https://tablas-frecuencia-d-noagrupados.onrender.com/",
    images: ["/img/TF/TFrecuencia.jpeg"],
  },
  {
    id: "siniestros",
    title: "Portal de Siniestros MVP",
    icon: "shield",
    description:
      "Plataforma full-stack de autoservicio para el reporte, seguimiento y gestión de siniestros de seguros.",
    longDesc:
      "Brinda visibilidad y trazabilidad de extremo a extremo del proceso de reclamación, resolviendo la incertidumbre del cliente y reduciendo la saturación operativa de los equipos de ajuste mediante autogestión 24/7.\n\n• Monorepo full-stack con separación estricta entre API (NestJS) y cliente (React), facilitando escalabilidad y despliegue independiente.\n• Autogestión 24/7 para el asegurado, reduciendo la dependencia de canales telefónicos.\n• Modelo de datos relacional en PostgreSQL gestionado con Prisma ORM, con migraciones versionadas.\n• Asignación inteligente de casos entre ajustadores según reglas de negocio.\n• Flujo de carga guiada de evidencias documentales para reducir errores en la apertura del expediente.\n• Tres roles operativos (cliente, ajustador, administrador) con vistas y permisos diferenciados.\n• Base de código 100% TypeScript de extremo a extremo.",
    tags: ["NestJS", "Prisma", "PostgreSQL", "React", "TailwindCSS", "TypeScript"],
    repo: "https://github.com/RocketDev-TV/Portal-siniestros-mvp",
  },
  {
    id: "agenda",
    title: "Agenda Web — Gestión de Contactos",
    icon: "contacts",
    description:
      "Aplicación web full-stack en Java Spring Boot que aplica el patrón MVC para la gestión segura de contactos y sus múltiples canales de comunicación.",
    longDesc:
      "Plataforma web basada en el patrón MVC para la gestión de una agenda personal, permitiendo a los usuarios registrarse, iniciar sesión y administrar contactos con múltiples medios de comunicación.\n\n• Arquitectura MVC clásica sobre Spring Boot 3.2.5, con separación de capas (controlador, servicio, repositorio).\n• Autenticación y registro de usuarios con aislamiento de datos por cuenta.\n• Modelo de datos que soporta múltiples medios de contacto por registro (correos, teléfonos, redes sociales).\n• Persistencia en PostgreSQL 16, contenerizada con Docker para entornos reproducibles.\n• Renderizado server-side con Thymeleaf, priorizando SEO y tiempos de carga.\n• Interfaz responsiva construida con Bootstrap 5.3.\n• Desarrollado en Java 21 como proyecto académico para Programación Web, UPIICSA (IPN).",
    tags: ["Java", "Spring Boot", "PostgreSQL", "Docker", "Thymeleaf", "Bootstrap"],
    repo: "https://github.com/RocketDev-TV/ProyectoAgenda",
  },
];

const techCategories = [
  {
    name: "Backend, Core & Cloud",
    badges: [
      { label: "Java",       url: "https://img.shields.io/badge/Java-ED8B00?style=for-the-badge&logo=openjdk&logoColor=white" },
      { label: "Spring",     url: "https://img.shields.io/badge/Spring-6DB33F?style=for-the-badge&logo=spring&logoColor=white" },
      { label: "TypeScript", url: "https://img.shields.io/badge/TypeScript-007ACC?style=for-the-badge&logo=typescript&logoColor=white" },
      { label: "GraphQL",    url: "https://img.shields.io/badge/GraphQL-E10098?style=for-the-badge&logo=graphql&logoColor=white" },
      { label: "Prisma",     url: "https://img.shields.io/badge/Prisma-2D3748?style=for-the-badge&logo=prisma&logoColor=white" },
      { label: "Python",     url: "https://img.shields.io/badge/Python-3776AB?style=for-the-badge&logo=python&logoColor=white" },
      { label: "Flask",      url: "https://img.shields.io/badge/Flask-000000?style=for-the-badge&logo=flask&logoColor=white" },
      { label: "NestJS",     url: "https://img.shields.io/badge/NestJS-E0234E?style=for-the-badge&logo=nestjs&logoColor=white" },
      { label: "Node.js",    url: "https://img.shields.io/badge/Node.js-339933?style=for-the-badge&logo=nodedotjs&logoColor=white" },
      { label: "Azure",      url: "https://img.shields.io/badge/Azure-0078D4?style=for-the-badge&logo=microsoftazure&logoColor=white" },
    ],
  },
  {
    name: "Infraestructura, Redes & DevOps",
    badges: [
      { label: "Docker",       url: "https://img.shields.io/badge/Docker-2496ED?style=for-the-badge&logo=docker&logoColor=white" },
      { label: "Ubuntu Server",url: "https://img.shields.io/badge/Ubuntu_Server-E95420?style=for-the-badge&logo=ubuntu&logoColor=white" },
      { label: "Cloudflare",   url: "https://img.shields.io/badge/Cloudflare-F38020?style=for-the-badge&logo=cloudflare&logoColor=white" },
      { label: "Tailscale",    url: "https://img.shields.io/badge/Tailscale-242424?style=for-the-badge&logo=tailscale&logoColor=white" },
      { label: "Firebase",     url: "https://img.shields.io/badge/Firebase-FFCA28?style=for-the-badge&logo=firebase&logoColor=black" },
      { label: "Supabase",     url: "https://img.shields.io/badge/Supabase-3ECF8E?style=for-the-badge&logo=supabase&logoColor=white" },
      { label: "PostgreSQL",   url: "https://img.shields.io/badge/PostgreSQL-316192?style=for-the-badge&logo=postgresql&logoColor=white" },
    ],
  },
  {
    name: "Data Science & AI",
    badges: [
      { label: "Pandas", url: "https://img.shields.io/badge/Pandas-150458?style=for-the-badge&logo=pandas&logoColor=white" },
      { label: "NumPy",  url: "https://img.shields.io/badge/NumPy-013243?style=for-the-badge&logo=numpy&logoColor=white" },
      { label: "MySQL",  url: "https://img.shields.io/badge/MySQL-4479A1?style=for-the-badge&logo=mysql&logoColor=white" },
    ],
  },
  {
    name: "Web & Tools",
    badges: [
      { label: "HTML5",       url: "https://img.shields.io/badge/HTML5-E34F26?style=for-the-badge&logo=html5&logoColor=white" },
      { label: "CSS3",        url: "https://img.shields.io/badge/CSS3-1572B6?style=for-the-badge&logo=css3&logoColor=white" },
      { label: "Tailwind CSS",url: "https://img.shields.io/badge/Tailwind_CSS-38B2AC?style=for-the-badge&logo=tailwind-css&logoColor=white" },
      { label: "JavaScript",  url: "https://img.shields.io/badge/JavaScript-F7DF1E?style=for-the-badge&logo=javascript&logoColor=black" },
      { label: "React",       url: "https://img.shields.io/badge/React-20232A?style=for-the-badge&logo=react&logoColor=61DAFB" },
      { label: "Vite",        url: "https://img.shields.io/badge/Vite-646CFF?style=for-the-badge&logo=vite&logoColor=white" },
      { label: "Next.js",     url: "https://img.shields.io/badge/Next.js-000000?style=for-the-badge&logo=nextdotjs&logoColor=white" },
