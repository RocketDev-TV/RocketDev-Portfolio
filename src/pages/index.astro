    <section id="contact" class="bg-zinc-950 border border-zinc-800 p-8 md:p-20 rounded-[40px] md:rounded-[60px] mb-20 w-full overflow-hidden">
      <div class="text-center mb-12 md:mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-white mb-4 italic tracking-tighter">
          ¿Hablamos?
        </h2>
        <p class="text-zinc-500 font-medium text-sm md:text-base">
          Envíame un mensaje directo a mi correo personal.
        </p>
      </div>
      <ContactForm />
    </section>
  </main>
</Layout>

