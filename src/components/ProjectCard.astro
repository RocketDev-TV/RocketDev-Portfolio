---
interface Props {
	title: string;
	description: string;
	tags: string[];
	repoUrl: string;
	image?: string;
}

const { title, description, tags, repoUrl, image } = Astro.props;
---

<div class="group border border-zinc-800 p-5 rounded-2xl bg-zinc-900/50 hover:bg-zinc-900 hover:border-zinc-700 transition-all duration-300 shadow-xl">
	{image && <img src={image} alt={title} class="rounded-xl mb-4 w-full h-48 object-cover group-hover:scale-[1.02] transition-transform" />}
	<h3 class="text-xl font-bold text-white mb-2">{title}</h3>
	<p class="text-zinc-400 text-sm mb-4 leading-relaxed">{description}</p>
	<div class="flex flex-wrap gap-2 mb-6">
		{tags.map(tag => (
			<span class="bg-zinc-800 text-zinc-300 px-2 py-1 rounded-md text-xs font-mono border border-zinc-700">
				{tag}
			</span>
		))}
	</div>
	<a href={repoUrl} target="_blank" class="text-orange-500 text-sm font-semibold hover:text-orange-400 flex items-center gap-1 group/link">
		Explorar Código 
		<span class="group-hover/link:translate-x-1 transition-transform">→</span>
	</a>
</div>